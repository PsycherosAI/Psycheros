{
  "workspace": [
    "./packages/psycheros",
    "./packages/entity-core",
    "./packages/entity-loom",
    "./packages/launcher",
    "./packages/plugin-api"
  ],
  "nodeModulesDir": "auto",
  "tasks": {
    "test": "deno test -A packages/psycheros/tests/ packages/entity-core/tests/ packages/plugin-api/tests/",
    "fmt": "deno fmt",
    "fmt:check": "deno fmt --check"
  },
  "imports": {
    "@std/path": "jsr:@std/path@^1",
    "@std/async": "jsr:@std/async@^1",
    "@std/dotenv": "jsr:@std/dotenv@^0.225",
    "@std/fs": "jsr:@std/fs@^1",
    "@std/assert": "jsr:@std/assert@^1",
    "@db/sqlite": "jsr:@db/sqlite@^0.12",
    "@xenova/transformers": "npm:@huggingface/transformers@3.3.1",
    "@modelcontextprotocol/sdk": "npm:@modelcontextprotocol/sdk@^1",
    "jszip": "npm:jszip@^3"
  },
  "compilerOptions": {
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "strictBindCallApply": true,
    "strictPropertyInitialization": true,
    "noImplicitThis": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true
  },
  "lint": {
    "rules": {
      "exclude": ["no-slow-types"]
    },
    "exclude": [
      "packages/launcher-v2/"
    ]
  },
  "fmt": {
    "exclude": [
      "packages/launcher-v2/e2e/"
    ]
  },
  "allowScripts": [
    "npm:onnxruntime-node@1.20.1",
    "npm:protobufjs@7.5.4",
    "npm:sharp@0.33.5"
  ]
}
