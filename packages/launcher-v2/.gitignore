# Rust build artifacts
src-tauri/target/

# Bundled Deno sidecars — staged by scripts/setup.sh (dev) or CI (release),
# never committed (large + platform-specific binaries).
src-tauri/binaries/deno-*

# Generated icons (per-build artifacts of scripts/setup.sh or `cargo tauri icon`).
# A real product icon should replace these — see docs/release.md.
src-tauri/icons/*.png
src-tauri/icons/*.icns
src-tauri/icons/*.ico
src-tauri/icons/source.png
!src-tauri/icons/.gitkeep

# Tauri-generated schema files
src-tauri/gen/

# Release-bundle tarballs staged for inclusion as Tauri resources.
# Generated by scripts/setup.sh (placeholder) or scripts/bundle-source.sh
# (real, for CI).
src-tauri/resources/release-bundle.tar.gz
src-tauri/resources/

# Node modules if any frontend tooling is added later
node_modules/

# OS / editor noise
.DS_Store
*.swp
