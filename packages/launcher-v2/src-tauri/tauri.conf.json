{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Psycheros",
  "version": "0.0.1",
  "identifier": "ai.psycheros.launcher",
  "build": {
    "frontendDist": "../frontend"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Psycheros",
        "width": 1180,
        "height": 820,
        "minWidth": 820,
        "minHeight": 600,
        "fullscreen": false,
        "resizable": true,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "category": "Utility",
    "copyright": "",
    "longDescription": "Psycheros is a persistent AI entity. This desktop launcher installs the entity as an OS service (launchd on macOS, systemd-user on Linux, Task Scheduler on Windows) and provides a unified window for both the chat client and the launcher's manager surface.",
    "shortDescription": "Persistent AI entity, managed.",
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/deno"],
    "resources": ["resources/release-bundle.tar.gz"],
    "macOS": {
      "minimumSystemVersion": "12.0"
    },
    "windows": {
      "wix": {
        "language": "en-US"
      }
    },
    "linux": {
      "deb": {
        "depends": []
      }
    }
  }
}
