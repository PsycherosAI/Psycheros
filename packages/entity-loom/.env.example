# LLM Configuration for memory generation
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=google/gemini-2.5-flash
WORKER_MODEL=google/gemini-2.5-flash

# Server Configuration
# Port the wizard listens on (default: 3210)
# PORT=3210
# Interface to bind to (default: 127.0.0.1 — loopback only; set to 0.0.0.0
# to expose the wizard on the network)
# HOSTNAME=0.0.0.0
